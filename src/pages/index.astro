---
import GlassCard from '../components/GlassCard.astro';
import KpiCard from '../components/KpiCard.astro';
import KpiGrid from '../components/KpiGrid.astro';
import Layout from '../layouts/Layout.astro';
import PredictionCards from '../components/PredictionCards.astro';
import QuickActions from '../components/QuickActions.astro';
import SmartBanner from '../components/SmartBanner.astro';
import WeeklyVolumeChart from '../components/WeeklyVolumeChart.astro';
import { buildDashboardViewModel } from '../lib/dashboard-data.ts';
import { supabaseServerClient } from '../lib/supabase-server';

const auth = Astro.locals.auth!;
const supabase = supabaseServerClient(Astro.cookies);
const userId = auth.userId;

const since30 = new Date();
since30.setDate(since30.getDate() - 30);

const [profileResult, activeSessionResult, routinesResult, sessionsResult, recentSetsResult, historySetsResult, latestProgressLogResult] = await Promise.all([
  supabase.from('profiles').select('name').eq('id', userId).maybeSingle(),
  supabase
    .from('workout_sessions')
    .select('id, routine_name, started_at')
    .eq('user_id', userId)
    .is('completed_at', null)
    .is('cancelled_at', null)
    .order('started_at', { ascending: false })
    .limit(1),
  supabase
    .from('routines')
    .select(`
      id,
      name,
      goal,
      routine_exercises (
        exercises (muscle_groups)
      )
    `)
    .eq('user_id', userId)
    .order('created_at', { ascending: true }),
  supabase
    .from('workout_sessions')
    .select('id, completed_at, routine_name, total_volume')
    .eq('user_id', userId)
    .not('completed_at', 'is', null)
    .gte('completed_at', since30.toISOString())
    .order('completed_at', { ascending: false }),
  supabase
    .from('session_sets')
    .select(`
      session_id,
      weight,
      reps,
      completed,
      logged_at,
      exercise_name,
      exercises (muscle_groups),
      workout_sessions!inner (user_id, completed_at)
    `)
    .eq('workout_sessions.user_id', userId)
    .not('workout_sessions.completed_at', 'is', null)
    .eq('completed', true)
    .gte('logged_at', since30.toISOString()),
  supabase
    .from('session_sets')
    .select(`
      session_id,
      weight,
      reps,
      completed,
      logged_at,
      exercise_name,
      exercises (muscle_groups),
      workout_sessions!inner (user_id, completed_at)
    `)
    .eq('workout_sessions.user_id', userId)
    .not('workout_sessions.completed_at', 'is', null)
    .eq('completed', true),
  supabase
    .from('user_progress_logs')
    .select('log_date, body_weight_kg, fatigue_level, energy_level, sleep_quality, symptoms')
    .eq('user_id', userId)
    .order('log_date', { ascending: false })
    .limit(1),
]);

const userName = profileResult.data?.name?.trim() || auth.displayName;
const activeSession = activeSessionResult.data?.[0] ?? null;

function getRelationMuscleGroups(value: any): string[] {
  if (Array.isArray(value)) {
    return value.flatMap((item) => getRelationMuscleGroups(item?.muscle_groups ?? item?.exercises ?? []));
  }

  if (value && Array.isArray(value.muscle_groups)) {
    return value.muscle_groups;
  }

  return [];
}

const recentSets = (recentSetsResult.data ?? []).map((set: any) => ({
  session_id: set.session_id,
  weight: set.weight,
  reps: set.reps,
  completed: set.completed,
  logged_at: set.logged_at,
  exercise_name: set.exercise_name,
  exercises: { muscle_groups: getRelationMuscleGroups(set.exercises) },
}));

const historySets = (historySetsResult.data ?? []).map((set: any) => ({
  session_id: set.session_id,
  weight: set.weight,
  reps: set.reps,
  completed: set.completed,
  logged_at: set.logged_at,
  exercise_name: set.exercise_name,
  exercises: { muscle_groups: getRelationMuscleGroups(set.exercises) },
}));

const routines = (routinesResult.data ?? []).map((routine: any) => ({
  id: routine.id,
  name: routine.name,
  goal: routine.goal,
  routine_exercises: (routine.routine_exercises ?? []).map((item: any) => ({
    exercises: { muscle_groups: getRelationMuscleGroups(item.exercises) },
  })),
  muscle_groups: getRelationMuscleGroups((routine.routine_exercises ?? []).map((item: any) => item.exercises)),
}));

const muscleGroupsBySession = new Map<string, Set<string>>();
for (const set of recentSets) {
  if (!set.session_id) continue;
  const current = muscleGroupsBySession.get(set.session_id) ?? new Set<string>();
  for (const muscle of set.exercises?.muscle_groups ?? []) current.add(muscle);
  muscleGroupsBySession.set(set.session_id, current);
}

const sessions = (sessionsResult.data ?? []).map((session) => ({
  ...session,
  muscle_groups: Array.from(muscleGroupsBySession.get(session.id) ?? []),
}));

const latestProgressLog = latestProgressLogResult.data?.[0] ?? null;

const dashboard = buildDashboardViewModel({
  userName,
  activeSession,
  routines,
  sessions,
  recentSets,
  historySets,
  latestProgressLog,
});

const startHref = activeSession?.id
  ? `/session?session_id=${activeSession.id}`
  : dashboard.predictions.recommendedRoutine.id
    ? `/session?routine_id=${dashboard.predictions.recommendedRoutine.id}`
    : '/routines';

const nextRoutine = dashboard.sections.nextRoutine;
const recentSessionsList = dashboard.sections.recentSessions;
---

<Layout title="Inicio">
  <div class="flex flex-col gap-4 sm:gap-5">
    <section aria-labelledby="dashboard-heading" class="space-y-2">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">RESUMEN INTELIGENTE</p>
      <h1 id="dashboard-heading" class="text-4xl font-bold tracking-tight text-white sm:text-5xl">Hola, {userName}</h1>
      <p class="max-w-2xl text-sm leading-6 text-muted sm:text-base">Tu progreso, recuperación y próxima decisión en un dashboard más denso para revisar todo en segundos.</p>
    </section>

    <SmartBanner state={dashboard.banner} />

    <QuickActions startHref={startHref} />

    <KpiGrid>
      <KpiCard
        title="Volumen semanal"
        value={`${dashboard.kpis.weeklyVolume.total.toLocaleString()} kg`}
        subtitle="Carga total de los últimos 7 días."
        icon="monitoring"
        color="primary"
        delayMs={60}
      />
      <KpiCard
        title="Frecuencia"
        value={`${dashboard.kpis.weeklyFrequency.completed}/${dashboard.kpis.weeklyFrequency.goal}`}
        subtitle="Sesiones completadas frente a tu meta base."
        icon="event_available"
        color="accent"
        delayMs={120}
      />
      <KpiCard
        title="Racha"
        value={`${dashboard.kpis.streak.value} días`}
        subtitle={dashboard.kpis.streak.value === 0 ? 'Empieza hoy y construye consistencia.' : 'Tu constancia sigue activa.'}
        icon="local_fire_department"
        color="primary"
        sparklineData={dashboard.kpis.streak.sparkline}
        delayMs={180}
      />
      <KpiCard
        title="PR reciente"
        value={dashboard.kpis.recentPr.value}
        subtitle={dashboard.kpis.recentPr.detail}
        icon="workspace_premium"
        color="accent"
        badge={dashboard.kpis.recentPr.value !== 'Sin PRs' ? '¡Nuevo!' : null}
        delayMs={240}
      />
    </KpiGrid>

    <GlassCard class="fade-in-up border border-white/8 p-4 sm:p-5" style="animation-delay:150ms; animation-fill-mode:both;">
      <section aria-labelledby="next-routine-title" class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="space-y-3">
          <div class="flex flex-wrap items-center gap-2">
            <p id="next-routine-title" class="text-lg font-bold text-white">Próxima rutina</p>
            <span class="inline-flex items-center rounded-full border border-primary/25 bg-primary/12 px-2.5 py-1 text-[11px] font-semibold text-primary">{nextRoutine.goalLabel}</span>
          </div>
          <div class="space-y-1">
            <p class="text-2xl font-bold tracking-tight text-white">{nextRoutine.name}</p>
            <p class="text-sm text-white/72">Enfoque principal: <span class="font-medium capitalize text-white">{nextRoutine.muscleGroup}</span></p>
            <p class="text-sm text-white/72">Duración estimada: <span class="font-medium text-white">{nextRoutine.estimatedDuration ? `${nextRoutine.estimatedDuration} min` : 'Pendiente'}</span></p>
          </div>
        </div>

        <a href={nextRoutine.href} class="dashboard-focus-ring inline-flex min-h-11 items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-app-bg shadow-[0_10px_24px_rgba(60,249,26,0.22)] transition-transform hover:scale-[1.01]">
          Empezar
        </a>
      </section>
    </GlassCard>

    <WeeklyVolumeChart series={dashboard.chart.series} goalLine={dashboard.chart.goalLine} />

    <div class="grid gap-4 lg:grid-cols-[minmax(0,1.3fr)_minmax(18rem,0.9fr)]">
      <PredictionCards
        nextPr={dashboard.predictions.nextPr}
        recovery={dashboard.predictions.recovery}
        recommendedRoutine={dashboard.predictions.recommendedRoutine}
        recentPrs={dashboard.predictions.recentPrs}
        overtrainingMessage={dashboard.predictions.overtraining.isOvertraining ? dashboard.predictions.overtraining.message : ''}
      />

      <GlassCard class="p-4 sm:p-5">
        <section aria-labelledby="recent-sessions-title" class="space-y-3">
          <div>
            <h2 id="recent-sessions-title" class="text-lg font-bold text-white">Sesiones recientes</h2>
            <p class="text-sm text-muted">Tus últimas 3 sesiones completadas.</p>
          </div>

          {recentSessionsList.length > 0 ? (
            <ul class="space-y-2.5">
              {recentSessionsList.map((session) => (
                <li class="flex items-center justify-between gap-3 rounded-2xl border border-white/8 bg-white/4 px-3 py-3">
                  <div class="min-w-0">
                    <p class="truncate font-medium text-white">{session.routineName}</p>
                    <p class="text-xs capitalize text-muted">{session.muscleGroup} · {session.completedAtLabel}</p>
                  </div>
                  <span class="shrink-0 text-sm font-semibold text-primary">{session.volumeLabel}</span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm text-white/70">Completa una rutina y verás aquí tu historial inmediato.</p>
          )}
        </section>
      </GlassCard>
    </div>

  </div>
</Layout>
