---
const currentPath = Astro.url.pathname;
const auth = Astro.locals.auth;
const session = auth?.session ?? null;
const displayName = auth?.displayName ?? 'Usuario';
const initials = auth?.initials ?? 'US';

const navItems = [
  { href: '/', label: 'Inicio', icon: 'home', active: currentPath === '/' },
  { href: '/routines', label: 'Rutinas', icon: 'fitness_center', active: currentPath === '/routines' },
  { href: '/calendar', label: 'Calendario', icon: 'calendar_month', active: currentPath === '/calendar' },
  { href: '/statistics', label: 'Stats', icon: 'bar_chart', active: currentPath === '/statistics' },
  { href: '/progress', label: 'Progreso', icon: 'trending_up', active: currentPath === '/progress' },
  { href: '/profile', label: 'Perfil', icon: 'account_circle', active: currentPath === '/profile' },
];
---

{session && (
  <>
    {/* Bottom Floating Bar */}
    <nav 
      aria-label="Navegación principal" 
      class="fixed bottom-0 left-0 right-0 z-50 sm:hidden"
    >
      <div class="flex justify-center px-4 pb-4 pt-2">
        <div class="flex max-w-full items-center gap-1 overflow-x-auto rounded-full border border-white/10 bg-surface/95 px-2 py-2 shadow-[0_8px_32px_rgba(0,0,0,0.5)] backdrop-blur-xl">
          {navItems.map((item) => (
            <a
              href={item.href}
              aria-current={item.active ? 'page' : undefined}
              class={`group flex min-h-[48px] min-w-[56px] flex-col items-center justify-center gap-0.5 rounded-full px-2 py-1 text-[10px] font-medium transition-all duration-200 ${item.active ? 'bg-primary/15 text-primary' : 'text-white/60 hover:bg-white/5 hover:text-white'}`}
            >
              <span 
                class="material-symbols-outlined text-[20px] transition-transform duration-200 group-active:scale-90" 
                style={item.active ? "font-variation-settings: 'FILL' 1;" : ''} 
                aria-hidden="true"
              >
                {item.icon}
              </span>
              <span class="leading-none">{item.label}</span>
            </a>
          ))}

          <button
            id="bottom-nav-more-trigger"
            type="button"
            aria-label="Abrir más opciones"
            aria-controls="bottom-nav-drawer"
            aria-expanded="false"
            class="group flex min-h-[48px] min-w-[56px] flex-col items-center justify-center gap-0.5 rounded-full px-2 py-1 text-[10px] font-medium text-white/60 transition-all duration-200 hover:bg-white/5 hover:text-white"
          >
            <span class="material-symbols-outlined text-[20px] transition-transform duration-200 group-active:scale-90" aria-hidden="true">more_horiz</span>
            <span class="leading-none">Más</span>
          </button>
        </div>
      </div>
    </nav>

    {/* Backdrop */}
    <div 
      id="bottom-nav-backdrop" 
      class="fixed inset-0 z-40 hidden bg-black/60 backdrop-blur-sm transition-opacity duration-300 opacity-0 sm:hidden"
      aria-hidden="true"
    ></div>

    {/* Drawer */}
    <aside 
      id="bottom-nav-drawer" 
      aria-hidden="true" 
      class="fixed inset-x-0 bottom-0 z-50 translate-y-full rounded-t-3xl border-t border-white/10 bg-[#0a0a0a] px-5 pb-8 pt-4 text-white transition-transform duration-300 ease-out sm:hidden"
    >
      {/* Drag handle */}
      <div class="mx-auto mb-5 flex justify-center">
        <div id="bottom-nav-drag-handle" class="h-1 w-12 rounded-full bg-white/20"></div>
      </div>

      <div class="mx-auto flex w-full max-w-md flex-col gap-4">
        {/* User info */}
        <div class="flex items-center gap-3">
          <div class="flex size-10 items-center justify-center rounded-full border border-primary/30 bg-primary/12 text-sm font-bold text-primary">
            {initials}
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-primary">Mi gimnasio</p>
            <p class="text-base font-semibold text-white">{displayName}</p>
          </div>
        </div>

        {/* Navigation links */}
        <nav aria-label="Menú completo" class="space-y-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              aria-current={item.active ? 'page' : undefined}
              class={`flex min-h-[44px] items-center justify-between rounded-xl border px-4 py-2.5 transition-colors ${item.active ? 'border-primary/30 bg-primary/10 text-primary' : 'border-white/8 bg-white/4 text-white hover:bg-white/8'}`}
            >
              <span class="flex items-center gap-3">
                <span class="material-symbols-outlined" style={item.active ? "font-variation-settings: 'FILL' 1;" : ''} aria-hidden="true">{item.icon}</span>
                <span class="font-medium">{item.label}</span>
              </span>
              <span class="material-symbols-outlined text-white/40 text-sm" aria-hidden="true">chevron_right</span>
            </a>
          ))}
        </nav>

        {/* Sign out */}
        <a 
          href="/api/auth/signout" 
          class="flex min-h-[44px] items-center justify-center rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-2.5 text-sm font-semibold text-red-300 transition-colors hover:bg-red-500/15"
        >
          Cerrar sesión
        </a>
      </div>
    </aside>

    <script is:inline>
      (function() {
        'use strict';
        
        const drawer = document.getElementById('bottom-nav-drawer');
        const backdrop = document.getElementById('bottom-nav-backdrop');
        const openBtn = document.getElementById('bottom-nav-more-trigger');
        const dragHandle = document.getElementById('bottom-nav-drag-handle');
        
        if (!drawer || !backdrop || !openBtn) return;
        
        let isOpen = false;
        let touchStartY = 0;
        let touchCurrentY = 0;
        let isDragging = false;
        
        function updateState(open) {
          isOpen = open;
          openBtn.setAttribute('aria-expanded', String(open));
          drawer.setAttribute('aria-hidden', String(!open));
          
          if (open) {
            backdrop.classList.remove('hidden');
            // Force reflow
            void backdrop.offsetWidth;
            backdrop.classList.remove('opacity-0');
            backdrop.classList.add('opacity-100');
            
            drawer.classList.remove('translate-y-full');
            document.body.style.overflow = 'hidden';
          } else {
            backdrop.classList.remove('opacity-100');
            backdrop.classList.add('opacity-0');
            drawer.classList.add('translate-y-full');
            document.body.style.overflow = '';
            
            setTimeout(function() {
              if (!isOpen) backdrop.classList.add('hidden');
            }, 300);
          }
        }
        
        function openDrawer() {
          if (isOpen) return;
          updateState(true);
        }
        
        function closeDrawer() {
          if (!isOpen) return;
          updateState(false);
        }
        
        // Open button
        openBtn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          openDrawer();
        });
        
        // Backdrop click
        backdrop.addEventListener('click', function(e) {
          e.preventDefault();
          closeDrawer();
        });
        
        // Close on Escape
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && isOpen) {
            closeDrawer();
          }
        });
        
        // Touch handling for swipe to close
        function onTouchStart(e) {
          touchStartY = e.touches[0]?.clientY || 0;
          touchCurrentY = touchStartY;
          isDragging = true;
        }
        
        function onTouchMove(e) {
          if (!isDragging) return;
          touchCurrentY = e.touches[0]?.clientY || touchStartY;
          const offset = Math.max(0, touchCurrentY - touchStartY);
          if (offset > 0) {
            drawer.style.transform = 'translateY(' + offset + 'px)';
          }
        }
        
        function onTouchEnd() {
          if (!isDragging) return;
          isDragging = false;
          const offset = Math.max(0, touchCurrentY - touchStartY);
          drawer.style.transform = '';
          if (offset > 60) {
            closeDrawer();
          }
        }
        
        // Add touch listeners to drawer and drag handle
        drawer.addEventListener('touchstart', onTouchStart, { passive: true });
        drawer.addEventListener('touchmove', onTouchMove, { passive: true });
        drawer.addEventListener('touchend', onTouchEnd);
        
        if (dragHandle) {
          dragHandle.addEventListener('touchstart', onTouchStart, { passive: true });
          dragHandle.addEventListener('touchmove', onTouchMove, { passive: true });
          dragHandle.addEventListener('touchend', onTouchEnd);
        }
        
        // Close drawer when clicking links inside it
        const drawerLinks = drawer.querySelectorAll('a');
        drawerLinks.forEach(function(link) {
          link.addEventListener('click', function() {
            closeDrawer();
          });
        });
        
        // Ensure drawer is closed on page load/navigation
        updateState(false);
        
        // Handle visibility change (when user comes back to page)
        document.addEventListener('visibilitychange', function() {
          if (!document.hidden && isOpen) {
            closeDrawer();
          }
        });
      })();
    </script>
  </>
)}
