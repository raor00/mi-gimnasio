---
const currentPath = Astro.url.pathname;
const auth = Astro.locals.auth;
const session = auth?.session ?? null;
const displayName = auth?.displayName ?? 'Usuario';
const initials = auth?.initials ?? 'US';

const navItems = [
  { href: '/', label: 'Inicio', icon: 'home', active: currentPath === '/' },
  { href: '/routines', label: 'Rutinas', icon: 'fitness_center', active: currentPath === '/routines' },
  { href: '/calendar', label: 'Calendario', icon: 'calendar_month', active: currentPath === '/calendar' },
  { href: '/statistics', label: 'Stats', icon: 'bar_chart', active: currentPath === '/statistics' },
];
---

{session && (
  <>
    <div class="pointer-events-none fixed inset-x-0 bottom-4 z-40 flex justify-center px-4 sm:hidden">
      <nav aria-label="Navegación principal" class="pointer-events-auto w-full max-w-sm rounded-full border border-white/10 bg-surface/90 px-2 py-2 shadow-[0_18px_50px_rgba(0,0,0,0.45)] backdrop-blur-xl">
        <ul class="grid grid-cols-5 gap-1">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={item.active ? 'page' : undefined}
                class={`dashboard-focus-ring flex min-h-11 flex-col items-center justify-center gap-1 rounded-full px-2 py-2 text-[11px] font-medium transition-colors ${item.active ? 'bg-primary/12 text-primary' : 'text-white/68 hover:bg-white/6 hover:text-white'}`}
              >
                <span class="material-symbols-outlined text-[22px]" style={item.active ? "font-variation-settings: 'FILL' 1;" : ''} aria-hidden="true">{item.icon}</span>
                <span>{item.label}</span>
              </a>
            </li>
          ))}

          <li>
            <button
              id="bottom-nav-more-trigger"
              type="button"
              aria-label="Abrir más opciones"
              aria-controls="bottom-nav-drawer"
              aria-expanded="false"
              class="dashboard-focus-ring flex min-h-11 w-full flex-col items-center justify-center gap-1 rounded-full px-2 py-2 text-[11px] font-medium text-white/68 transition-colors hover:bg-white/6 hover:text-white"
            >
              <span class="material-symbols-outlined text-[22px]" aria-hidden="true">more_horiz</span>
              <span>Más</span>
            </button>
          </li>
        </ul>
      </nav>
    </div>

    <div id="bottom-nav-backdrop" class="fixed inset-0 z-40 hidden bg-black/70 backdrop-blur-sm sm:hidden"></div>

    <aside id="bottom-nav-drawer" aria-hidden="true" class="fixed inset-x-0 bottom-0 z-50 hidden translate-y-full rounded-t-[2rem] border-t border-white/10 bg-[#0a0a0a]/98 px-5 pb-8 pt-4 text-white transition-transform duration-300 ease-out sm:hidden">
      <div class="mx-auto flex w-full max-w-md flex-col gap-5">
        <div class="flex items-start justify-between gap-4">
          <div>
            <div class="mx-auto mb-4 h-1.5 w-14 rounded-full bg-white/12"></div>
            <div class="flex items-center gap-3">
              <div class="flex size-12 items-center justify-center rounded-full border border-primary/30 bg-primary/12 text-sm font-bold text-primary">{initials}</div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Mi gimnasio</p>
                <p class="text-lg font-semibold text-white">{displayName}</p>
              </div>
            </div>
          </div>

          <button id="bottom-nav-close" type="button" aria-label="Cerrar menú" class="dashboard-focus-ring flex min-h-11 min-w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 text-white/80 transition-colors hover:bg-white/10 hover:text-white">
            <span class="material-symbols-outlined" aria-hidden="true">close</span>
          </button>
        </div>

        <nav aria-label="Menú completo" class="space-y-2">
          {navItems.map((item) => (
            <a
              href={item.href}
              aria-current={item.active ? 'page' : undefined}
              class={`dashboard-focus-ring flex min-h-11 items-center justify-between rounded-2xl border px-4 py-3 transition-colors ${item.active ? 'border-primary/30 bg-primary/10 text-primary' : 'border-white/8 bg-white/4 text-white hover:bg-white/8'}`}
            >
              <span class="flex items-center gap-3">
                <span class="material-symbols-outlined" style={item.active ? "font-variation-settings: 'FILL' 1;" : ''} aria-hidden="true">{item.icon}</span>
                <span class="font-medium">{item.label}</span>
              </span>
              <span class="material-symbols-outlined text-white/45" aria-hidden="true">chevron_right</span>
            </a>
          ))}
        </nav>

        <a href="/api/auth/signout" class="dashboard-focus-ring inline-flex min-h-11 items-center justify-center rounded-2xl border border-red-500/20 bg-red-500/10 px-4 py-3 font-semibold text-red-300 transition-colors hover:bg-red-500/15">
          Cerrar sesión
        </a>
      </div>
    </aside>

    <script is:inline>
      const drawer = document.getElementById('bottom-nav-drawer');
      const backdrop = document.getElementById('bottom-nav-backdrop');
      const openButton = document.getElementById('bottom-nav-more-trigger');
      const closeButton = document.getElementById('bottom-nav-close');

      let touchStartY = 0;
      let touchCurrentY = 0;
      let isOpen = false;
      let hideTimer = 0;

      function syncState(open) {
        isOpen = open;
        openButton?.setAttribute('aria-expanded', String(open));
        drawer?.setAttribute('aria-hidden', String(!open));
        document.body.style.overflow = open ? 'hidden' : '';
      }

      function openDrawer() {
        if (!drawer || !backdrop || isOpen) return;
        window.clearTimeout(hideTimer);
        drawer.classList.remove('hidden');
        backdrop.classList.remove('hidden');
        requestAnimationFrame(() => {
          drawer.classList.remove('translate-y-full');
        });
        syncState(true);
      }

      function closeDrawer() {
        if (!drawer || !backdrop || !isOpen) return;
        drawer.style.transform = '';
        drawer.classList.add('translate-y-full');
        backdrop.classList.add('hidden');
        syncState(false);
        hideTimer = window.setTimeout(() => drawer.classList.add('hidden'), 300);
      }

      openButton?.addEventListener('click', openDrawer);
      closeButton?.addEventListener('click', closeDrawer);
      backdrop?.addEventListener('click', closeDrawer);

      drawer?.addEventListener('touchstart', (event) => {
        touchStartY = event.touches[0]?.clientY ?? 0;
        touchCurrentY = touchStartY;
      }, { passive: true });

      drawer?.addEventListener('touchmove', (event) => {
        touchCurrentY = event.touches[0]?.clientY ?? touchStartY;
        const offset = Math.max(0, touchCurrentY - touchStartY);
        if (offset > 0) {
          drawer.style.transform = `translateY(${offset}px)`;
        }
      }, { passive: true });

      drawer?.addEventListener('touchend', () => {
        const offset = Math.max(0, touchCurrentY - touchStartY);
        drawer.style.transform = '';
        if (offset > 72) {
          closeDrawer();
        }
      });
    </script>
  </>
)}
