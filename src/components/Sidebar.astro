---
const currentPath = Astro.url.pathname;
const auth = Astro.locals.auth;
const session = auth?.session ?? null;
const displayName = auth?.displayName ?? 'Usuario';
const initials = auth?.initials ?? 'US';

const navItems = [
  { href: '/', label: 'Inicio', icon: 'home' },
  { href: '/routines', label: 'Rutinas', icon: 'fitness_center' },
  { href: '/calendar', label: 'Calendario', icon: 'calendar_month' },
  { href: '/statistics', label: 'Estadísticas', icon: 'bar_chart' },
];
---

{session && (
  <aside class="hidden w-[248px] shrink-0 border-r border-surface-border/80 bg-surface/70 p-4 backdrop-blur-xl sm:flex sm:flex-col sm:justify-between">
    <div class="flex flex-col gap-8">
      <div class="flex items-center gap-3 rounded-2xl border border-white/8 bg-white/4 px-3 py-3">
        <div class="flex size-11 items-center justify-center rounded-full border border-primary/35 bg-primary/12 text-sm font-bold text-primary">{initials}</div>
        <div class="min-w-0">
          <p class="truncate text-base font-semibold text-white">{displayName}</p>
          <p class="text-xs uppercase tracking-[0.18em] text-primary">Miembro activo</p>
        </div>
      </div>

      <nav aria-label="Navegación principal" class="flex flex-col gap-2">
        {navItems.map((item) => {
          const active = currentPath === item.href;

          return (
            <a
              href={item.href}
              aria-current={active ? 'page' : undefined}
              class={`dashboard-focus-ring flex min-h-11 items-center gap-3 rounded-2xl border px-3 py-3 transition-colors ${active ? 'border-primary/25 bg-primary/10 text-primary' : 'border-transparent text-muted hover:border-white/8 hover:bg-white/5 hover:text-white'}`}
            >
              <span class="material-symbols-outlined" style={active ? "font-variation-settings: 'FILL' 1;" : ''} aria-hidden="true">{item.icon}</span>
              <span class="text-sm font-medium">{item.label}</span>
            </a>
          );
        })}
      </nav>
    </div>

    <a href="/api/auth/signout" class="dashboard-focus-ring mt-8 inline-flex min-h-11 items-center gap-3 rounded-2xl border border-red-500/20 px-3 py-3 text-sm font-medium text-red-400 transition-colors hover:bg-red-500/10">
      <span class="material-symbols-outlined" aria-hidden="true">logout</span>
      <span>Cerrar sesión</span>
    </a>
  </aside>
)}
