---
import GlassCard from './GlassCard.astro';

interface Props {
  title: string;
  value: string;
  subtitle: string;
  icon: string;
  color?: 'primary' | 'accent' | 'neutral';
  sparklineData?: number[];
  badge?: string | null;
  delayMs?: number;
}

const {
  title,
  value,
  subtitle,
  icon,
  color = 'neutral',
  sparklineData = [],
  badge = null,
  delayMs = 0,
} = Astro.props;

const accentClasses = {
  primary: 'text-primary bg-primary/12 border-primary/20',
  accent: 'text-accent bg-accent/12 border-accent/20',
  neutral: 'text-white bg-white/8 border-white/10',
};

const maxSparkline = Math.max(...sparklineData, 1);
const sparklinePoints = sparklineData
  .map((point, index) => {
    const x = sparklineData.length === 1 ? 100 : (index / Math.max(sparklineData.length - 1, 1)) * 100;
    const y = 100 - (point / maxSparkline) * 100;
    return `${x},${Number.isFinite(y) ? y : 100}`;
  })
  .join(' ');
---

<GlassCard class="fade-in-up motion-card px-4 py-4" style={`animation-delay:${delayMs}ms; animation-fill-mode: both;`}>
  <article aria-label={`${title}: ${value}`} class="flex h-full flex-col gap-3">
    <div class="flex items-start justify-between gap-3">
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.16em] text-white/55">{title}</p>
        <p class="count-up mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl">{value}</p>
      </div>

      <div class={`flex size-10 items-center justify-center rounded-2xl border ${accentClasses[color]}`}>
        <span class="material-symbols-outlined" aria-hidden="true">{icon}</span>
      </div>
    </div>

    <div class="mt-auto space-y-2.5">
      <p class="text-sm leading-5 text-white/68">{subtitle}</p>

      {sparklineData.length > 1 && (
        <svg viewBox="0 0 100 100" class="h-9 w-full overflow-visible" aria-hidden="true" focusable="false">
          <polyline
            points={sparklinePoints}
            fill="none"
            stroke="currentColor"
            stroke-width="6"
            stroke-linecap="round"
            stroke-linejoin="round"
            class={color === 'primary' ? 'text-primary' : color === 'accent' ? 'text-accent' : 'text-white/70'}
          />
        </svg>
      )}

      {badge && (
        <span class="inline-flex w-fit items-center rounded-full border border-primary/25 bg-primary/12 px-2.5 py-1 text-[11px] font-semibold text-primary">
          {badge}
        </span>
      )}
    </div>
  </article>
</GlassCard>
