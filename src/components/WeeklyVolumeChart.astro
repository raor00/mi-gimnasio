---
import GlassCard from './GlassCard.astro';
import type { WeeklyVolumePoint } from '../lib/predictions.ts';

interface Props {
  series: WeeklyVolumePoint[];
  goalLine?: number;
}

const { series, goalLine = 0 } = Astro.props;
const seriesJson = JSON.stringify(series);
---

<GlassCard class="fade-in-up p-4 sm:p-5" style="animation-delay:180ms; animation-fill-mode:both;">
  <section aria-labelledby="dashboard-volume-title" class="space-y-3">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 id="dashboard-volume-title" class="text-lg font-bold text-white sm:text-xl">Volumen semanal</h2>
        <p class="text-sm text-muted">Últimos 7 días · peso × repeticiones</p>
      </div>
      <p class="text-xs text-white/70 sm:text-sm">Meta diaria: <span class="font-semibold text-accent">{goalLine.toLocaleString()} kg</span></p>
    </div>

    <div class="h-[180px] sm:h-[240px]">
      <canvas id="dashboard-weekly-volume-chart" aria-label="Gráfico de volumen semanal" role="img"></canvas>
    </div>
  </section>
</GlassCard>

<script is:inline define:vars={{ seriesJson, goalLine }}>
  const weeklyVolumeSeries = JSON.parse(seriesJson);
  let dashboardChartPromise = null;

  function loadChartJs() {
    if (window.Chart) return Promise.resolve(window.Chart);
    if (dashboardChartPromise) return dashboardChartPromise;

    dashboardChartPromise = new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
      script.async = true;
      script.onload = () => resolve(window.Chart);
      script.onerror = () => reject(new Error('No se pudo cargar Chart.js'));
      document.head.appendChild(script);
    });

    return dashboardChartPromise;
  }

  async function initDashboardWeeklyVolumeChart() {
    const canvas = document.getElementById('dashboard-weekly-volume-chart');
    if (!canvas) return;

    await loadChartJs();
    const ctx = canvas.getContext('2d');
    if (!ctx || !window.Chart) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    new Chart(ctx, {
      data: {
        labels: weeklyVolumeSeries.map((item) => item.label),
        datasets: [
          {
            type: 'bar',
            data: weeklyVolumeSeries.map((item) => item.volume),
            backgroundColor: 'rgba(0, 212, 255, 0.75)',
            borderRadius: 14,
            borderSkipped: false,
            hoverBackgroundColor: '#00D4FF',
          },
          {
            type: 'line',
            data: weeklyVolumeSeries.map(() => goalLine),
            borderColor: 'rgba(60, 249, 26, 0.8)',
            borderDash: [6, 6],
            borderWidth: 2,
            pointRadius: 0,
            tension: 0,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: prefersReducedMotion ? false : { duration: 600, easing: 'easeOutQuart' },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: 'rgba(5,5,5,0.92)',
            borderColor: 'rgba(255,255,255,0.1)',
            borderWidth: 1,
            titleColor: '#fff',
            bodyColor: '#D1D5DB',
            callbacks: {
              label: (context) => context.dataset.type === 'line'
                ? ` Meta: ${Number(context.raw).toLocaleString()} kg`
                : ` Volumen: ${Number(context.raw).toLocaleString()} kg`,
            },
          },
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { color: '#9CA3AF' },
          },
          y: {
            beginAtZero: true,
            grid: { color: 'rgba(255,255,255,0.06)' },
            ticks: {
              color: '#9CA3AF',
              callback: (value) => `${Number(value).toLocaleString()} kg`,
            },
          },
        },
      },
    });
  }

  initDashboardWeeklyVolumeChart();
</script>
