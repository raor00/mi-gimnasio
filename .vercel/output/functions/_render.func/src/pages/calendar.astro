---
import Layout from '../layouts/Layout.astro';
import GlassCard from '../components/GlassCard.astro';
import { supabaseServerClient } from '../lib/supabase-server';

const auth = Astro.locals.auth!;
const supabase = supabaseServerClient(Astro.cookies);
const userId = auth.userId;

const { data: completedSessions } = await supabase
  .from('workout_sessions')
  .select('id, routine_name, started_at, completed_at, total_volume')
  .eq('user_id', userId)
  .not('completed_at', 'is', null)
  .order('completed_at', { ascending: false });

// Build map: YYYY-MM-DD -> session[]
const sessionMap: Record<string, any[]> = {};
for (const s of (completedSessions || [])) {
  const key = new Date(s.completed_at).toISOString().split('T')[0];
  if (!sessionMap[key]) sessionMap[key] = [];
  sessionMap[key].push(s);
}

const sessionsJson = JSON.stringify(sessionMap);
const dayNames = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
---

<Layout title="Calendario">
  <div class="flex flex-col gap-8 w-full">
    <!-- Header -->
    <header class="flex flex-col sm:flex-row items-start sm:items-end justify-between w-full gap-4">
      <div class="flex flex-col gap-1">
        <h2 class="text-white text-3xl sm:text-[40px] font-bold leading-tight tracking-wide">Calendario de entrenamiento</h2>
        <p class="text-muted text-base">Visualiza tu constancia y tus sesiones completadas.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
        <div class="flex items-center gap-4 self-center">
          <button id="btn-prev" class="text-muted hover:text-white transition-colors flex items-center justify-center size-8 rounded-full hover:bg-surface-hover">
            <span class="material-symbols-outlined">chevron_left</span>
          </button>
          <span id="month-label" class="font-mono text-xl text-white w-44 text-center"></span>
          <button id="btn-next" class="text-muted hover:text-white transition-colors flex items-center justify-center size-8 rounded-full hover:bg-surface-hover">
            <span class="material-symbols-outlined">chevron_right</span>
          </button>
        </div>
        <div class="flex h-10 items-center justify-center rounded-full glass-card p-1 self-center">
          <button id="view-month" class="h-full px-6 rounded-full text-white bg-surface-hover text-sm font-medium transition-all">Mes</button>
          <button id="view-week" class="h-full px-6 rounded-full text-muted text-sm font-medium transition-all">Semana</button>
        </div>
      </div>
    </header>

    <!-- Legend -->
    <div class="flex flex-wrap gap-4 items-center justify-start sm:justify-end text-sm font-mono text-muted">
      <div class="flex items-center gap-2"><div class="size-2 rounded-full bg-primary shadow-[0_0_8px_rgba(60,249,26,0.5)]"></div> Completado</div>
      <div class="flex items-center gap-2"><div class="size-2 rounded-full bg-surface-border"></div> Descanso</div>
    </div>

    <!-- Calendar -->
    <div class="w-full overflow-x-auto pb-4">
      <GlassCard class="overflow-hidden min-w-[700px] flex flex-col p-0">
        <!-- Day Headers -->
        <div class="grid grid-cols-7 border-b border-surface-border bg-black/20">
          {dayNames.map(day => (
            <div class="p-4 text-center font-mono text-sm text-muted uppercase tracking-wider border-r border-surface-border last:border-r-0">{day}</div>
          ))}
        </div>
        <!-- Calendar Grid (rendered by JS) -->
        <div id="calendar-grid" class="grid grid-cols-7 bg-black/10"></div>
      </GlassCard>
    </div>

    <!-- Session Detail Tooltip -->
    <div id="session-detail" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
      <div class="absolute inset-0 bg-black/60" id="detail-backdrop"></div>
      <GlassCard class="relative z-10 p-6 max-w-sm w-full flex flex-col gap-4">
        <div class="flex justify-between items-start">
          <h3 id="detail-title" class="text-lg font-bold text-white"></h3>
          <button id="detail-close" class="text-muted hover:text-white"><span class="material-symbols-outlined">close</span></button>
        </div>
        <div id="detail-body" class="flex flex-col gap-3"></div>
      </GlassCard>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ sessionsJson }}>
  const sessionMap = JSON.parse(sessionsJson);
  const MONTHS = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  const TODAY = new Date();
  TODAY.setHours(0,0,0,0);

  let currentYear = TODAY.getFullYear();
  let currentMonth = TODAY.getMonth();
  let viewMode = 'month'; // 'month' | 'week'
  let weekOffset = 0; // for week navigation

  function toKey(date) {
    return date.toISOString().split('T')[0];
  }

  function renderMonth() {
    const grid = document.getElementById('calendar-grid');
    const label = document.getElementById('month-label');
    label.textContent = `${MONTHS[currentMonth]} ${currentYear}`;

    const firstDay = new Date(currentYear, currentMonth, 1).getDay();
    const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
    const totalCells = Math.ceil((firstDay + daysInMonth) / 7) * 7;

    let html = '';
    for (let i = 0; i < totalCells; i++) {
      const dayNum = i - firstDay + 1;
      const isCurrentMonth = dayNum >= 1 && dayNum <= daysInMonth;
      const date = isCurrentMonth ? new Date(currentYear, currentMonth, dayNum) : null;
      const key = date ? toKey(date) : null;
      const daySessions = key && sessionMap[key] ? sessionMap[key] : [];
      const isToday = date && date.getTime() === TODAY.getTime();
      const isPast = date && date < TODAY;

      html += `<button ${key ? `data-date="${key}"` : ''} class="cal-cell min-h-[100px] border-r border-b border-surface-border p-2 flex flex-col gap-1 hover:bg-surface-hover/50 transition-colors text-right ${!isCurrentMonth ? 'opacity-20 pointer-events-none' : ''}">
        <span class="font-mono text-sm ${isToday ? 'w-7 h-7 rounded-full bg-primary text-app-bg flex items-center justify-center font-bold ml-auto' : isPast && isCurrentMonth ? 'text-white/40' : 'text-white/70'}">${isCurrentMonth ? dayNum : ''}</span>
        <div class="flex flex-col gap-0.5 mt-auto w-full">
          ${daySessions.slice(0,2).map(s => `
            <div class="bg-primary/20 border border-primary/30 text-primary text-[10px] px-1.5 py-0.5 rounded w-full text-left truncate flex items-center gap-1">
              <div class="size-1.5 rounded-full bg-primary flex-shrink-0"></div>
              <span class="truncate">${s.routine_name}</span>
            </div>`).join('')}
          ${daySessions.length > 2 ? `<span class="text-[10px] text-primary/60 text-left pl-1">+${daySessions.length - 2} more</span>` : ''}
        </div>
      </button>`;
    }
    grid.innerHTML = html;
    bindCellClicks();
  }

  function renderWeek() {
    const grid = document.getElementById('calendar-grid');
    const label = document.getElementById('month-label');

    const startOfWeek = new Date(TODAY);
    startOfWeek.setDate(TODAY.getDate() - TODAY.getDay() + weekOffset * 7);
    const endOfWeek = new Date(startOfWeek);
    endOfWeek.setDate(startOfWeek.getDate() + 6);

      label.textContent = `${startOfWeek.toLocaleDateString('es',{month:'short',day:'numeric'})} – ${endOfWeek.toLocaleDateString('es',{month:'short',day:'numeric',year:'numeric'})}`;

    let html = '';
    for (let i = 0; i < 7; i++) {
      const date = new Date(startOfWeek);
      date.setDate(startOfWeek.getDate() + i);
      const key = toKey(date);
      const daySessions = sessionMap[key] || [];
      const isToday = date.getTime() === TODAY.getTime();

      html += `<button data-date="${key}" class="cal-cell min-h-[160px] border-r border-b border-surface-border p-3 flex flex-col gap-2 hover:bg-surface-hover/50 transition-colors">
        <span class="font-mono text-sm ${isToday ? 'w-7 h-7 rounded-full bg-primary text-app-bg flex items-center justify-center font-bold' : 'text-white/60'}">${date.getDate()}</span>
        <div class="flex flex-col gap-1 w-full flex-1">
          ${daySessions.map(s => `
            <div class="bg-primary/20 border border-primary/30 text-primary text-xs px-2 py-1 rounded w-full text-left flex flex-col gap-0.5">
              <span class="font-semibold truncate">${s.routine_name}</span>
              ${s.total_volume > 0 ? `<span class="text-primary/60 text-[10px]">${Math.round(s.total_volume).toLocaleString()} kg</span>` : ''}
            </div>`).join('')}
        </div>
      </button>`;
    }
    grid.innerHTML = html;
    bindCellClicks();
  }

  function bindCellClicks() {
    document.querySelectorAll('.cal-cell[data-date]').forEach(cell => {
      cell.addEventListener('click', () => showDetail(cell.dataset.date));
    });
  }

  function showDetail(dateKey) {
    const sessions = sessionMap[dateKey];
    if (!sessions || sessions.length === 0) return;
    const date = new Date(dateKey + 'T12:00:00');
    document.getElementById('detail-title').textContent = date.toLocaleDateString('es',{weekday:'long',month:'long',day:'numeric'});
    document.getElementById('detail-body').innerHTML = sessions.map(s => `
      <div class="p-3 rounded-lg bg-primary/10 border border-primary/20 flex flex-col gap-1">
        <p class="font-bold text-white">${s.routine_name}</p>
        ${s.total_volume > 0 ? `<p class="text-sm text-muted">${Math.round(s.total_volume).toLocaleString()} kg de volumen total</p>` : ''}
        <p class="text-xs text-muted">${new Date(s.started_at).toLocaleTimeString('es',{hour:'2-digit',minute:'2-digit'})}</p>
      </div>`).join('');
    document.getElementById('session-detail').classList.remove('hidden');
  }

  function render() {
    if (viewMode === 'month') renderMonth();
    else renderWeek();
  }

  document.getElementById('btn-prev').addEventListener('click', () => {
    if (viewMode === 'month') {
      currentMonth--; if (currentMonth < 0) { currentMonth = 11; currentYear--; }
    } else { weekOffset--; }
    render();
  });
  document.getElementById('btn-next').addEventListener('click', () => {
    if (viewMode === 'month') {
      currentMonth++; if (currentMonth > 11) { currentMonth = 0; currentYear++; }
    } else { weekOffset++; }
    render();
  });

  document.getElementById('view-month').addEventListener('click', () => {
    viewMode = 'month';
    document.getElementById('view-month').classList.add('text-white','bg-surface-hover');
    document.getElementById('view-month').classList.remove('text-muted');
    document.getElementById('view-week').classList.remove('text-white','bg-surface-hover');
    document.getElementById('view-week').classList.add('text-muted');
    render();
  });
  document.getElementById('view-week').addEventListener('click', () => {
    viewMode = 'week';
    document.getElementById('view-week').classList.add('text-white','bg-surface-hover');
    document.getElementById('view-week').classList.remove('text-muted');
    document.getElementById('view-month').classList.remove('text-white','bg-surface-hover');
    document.getElementById('view-month').classList.add('text-muted');
    render();
  });

  document.getElementById('detail-close').addEventListener('click', () => document.getElementById('session-detail').classList.add('hidden'));
  document.getElementById('detail-backdrop').addEventListener('click', () => document.getElementById('session-detail').classList.add('hidden'));

  render();
</script>
